# Copy this file to .env and .env.local and fill in the values
# NEVER commit .env or .env.local to version control

# Rails secret key base - generate with: rails secret
SECRET_KEY_BASE=your-generated-secret-key-here

# Database configuration (if using non-SQLite in production)
# DATABASE_URL=postgres://user:password@localhost/dbname

# Email configuration (if sending emails)
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@example.com
# SMTP_PASSWORD=your-password
